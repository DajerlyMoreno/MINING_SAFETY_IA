# ── Entorno virtual Python ─────────────────────────────────────────
env/
venv/
.venv/
env.bak/
venv.bak/
__pypackages__/

# ── Python bytecode y cache ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
cython_debug/

# ── Base de datos SQLite (se genera automaticamente al arrancar) ───
*.db
*.db-journal
*.db-shm
*.db-wal
mineria_ia.db

# ── Variables de entorno y secretos ───────────────────────────────
.env
.env.*
.envrc
!.env.example

# ── Logs del sistema ───────────────────────────────────────────────
logs/
*.log
pip-log.txt

# ── Modelos ML — backups y temporales ─────────────────────────────
# Los .keras se versionan para evitar tener que reentrenar.
# Solo se ignoran los backups generados al parchear los archivos.
modelos/_backup/
*.keras.bak

# ── Indice FAISS (se reconstruye automaticamente) ──────────────────
rag_data/faiss_index/

# ── Frontend — Node.js / pnpm ─────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
# pnpm — el lockfile SÍ se versiona (garantiza reproducibilidad)
# pnpm-lock.yaml  <- NO ignorar
.pnpm-store/
.pnpm-debug.log

# ── Distribucion y empaquetado Python ─────────────────────────────
*.egg-info/
*.egg
dist/
build/
.eggs/
MANIFEST

# ── Jupyter / IPython ─────────────────────────────────────────────
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── IDEs ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.spyderproject
.spyproject
.ropeproject

# ── Sistema operativo ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Cobertura de tests ────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Miscelaneos ───────────────────────────────────────────────────
tempCodeRunnerFile.py
.abstra/
.streamlit/secrets.toml

DOCS/